# ================================================================
#  INOV INTRANET — Backend .htaccess
#  Security + URL Rewriting + Performance for PHP API
# ================================================================

Options -Indexes -ExecCGI -Includes

# ── Rewrite Engine ──────────────────────────────────────────────
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to sensitive directories (NOT storage/uploads — serves images)
RewriteRule ^(config|core|models|controllers|middlewares|helpers|database|logs)/ - [F,L]

# Allow direct access to uploaded static files (images, PDFs, SVGs)
RewriteCond %{REQUEST_URI} ^/backend/storage/uploads/
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Block direct access to PHP files (except index.php)
RewriteCond %{REQUEST_URI} !/index\.php$
RewriteRule \.php$ - [F,L]

# Route ALL requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# ── Security Headers ────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS — força HTTPS durante 1 ano
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ── Block dangerous file types ───────────────────────────────────
<FilesMatch "\.(phtml|php3|php4|php5|asp|aspx|cgi|sh|py|rb|pl|exe|bat|cmd|jar)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# ── Block access to dotfiles ─────────────────────────────────────
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Disable signature ────────────────────────────────────────────
ServerSignature Off

# ── Charset ──────────────────────────────────────────────────────
AddDefaultCharset UTF-8

# ── MIME Types ───────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType application/json         .json
    AddType image/svg+xml            .svg
    AddType application/pdf          .pdf
    AddType font/woff                .woff
    AddType font/woff2               .woff2
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/json application/javascript
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
    # Não comprimir já comprimidos
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|zip|gz|bz2)$ no-gzip
</IfModule>

# ── Cache Headers para ficheiros estáticos (uploads) ─────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Imagens: 30 dias
    ExpiresByType image/jpeg            "access plus 30 days"
    ExpiresByType image/png             "access plus 30 days"
    ExpiresByType image/gif             "access plus 30 days"
    ExpiresByType image/webp            "access plus 30 days"
    ExpiresByType image/svg+xml         "access plus 30 days"
    # PDFs / documentos: 7 dias
    ExpiresByType application/pdf       "access plus 7 days"
    # Fontes: 1 ano
    ExpiresByType font/woff             "access plus 1 year"
    ExpiresByType font/woff2            "access plus 1 year"
</IfModule>

# Cache-Control para uploads (só aplica a ficheiros reais em storage)
<FilesMatch "\.(jpe?g|png|gif|webp|svg|pdf|woff2?)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
    </IfModule>
</FilesMatch>
